generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Seller {
  id            Int      @id @default(autoincrement())
  sellerId      String   @unique @map("seller_id")
  name          String
  email         String   @unique
  phone         String
  passwordHash  String   @map("password_hash")
  role          Role     @default(SELLER)
  walletBalance Decimal  @default(0) @db.Decimal(10, 2) @map("wallet_balance")
  createdAt     DateTime @default(now()) @map("created_at")

  orders       Order[]
  transactions WalletTransaction[]

  @@map("sellers")
}

model Product {
  id            Int      @id @default(autoincrement())
  productId     String   @unique @map("product_id")
  title         String
  description   String?
  sourcingPrice Decimal  @db.Decimal(10, 2) @map("sourcing_price")
  sellingPrice  Decimal  @db.Decimal(10, 2) @map("selling_price")
  stockQuantity Int      @default(0) @map("stock_quantity")
  imageUrl      String?  @map("image_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("products")
}

model Order {
  id            Int         @id @default(autoincrement())
  orderId       String      @unique @map("order_id")
  sellerId      String      @map("seller_id")
  productId     String      @map("product_id")
  customerName  String      @map("customer_name")
  customerPhone String      @map("customer_phone")
  city          String
  region        String
  address       String?
  quantity      Int         @default(1)
  shippingFee   Decimal     @default(30) @db.Decimal(10, 2) @map("shipping_fee")
  status        OrderStatus @default(PENDING_BALANCE)
  notes         String?
  callAttempts  Int         @default(0) @map("call_attempts")
  lastCallAt    DateTime?   @map("last_call_at")
  confirmedAt   DateTime?   @map("confirmed_at")
  shippedAt     DateTime?   @map("shipped_at")
  deliveredAt   DateTime?   @map("delivered_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  seller  Seller  @relation(fields: [sellerId], references: [sellerId])
  product Product @relation(fields: [productId], references: [productId])

  @@map("orders")
}

model WalletTransaction {
  id            Int               @id @default(autoincrement())
  transactionId String            @unique @map("transaction_id")
  sellerId      String            @map("seller_id")
  amount        Decimal           @db.Decimal(10, 2)
  type          TransactionType
  description   String?
  receiptUrl    String?           @map("receipt_url")
  status        TransactionStatus @default(PENDING)
  approvedBy    String?           @map("approved_by")
  approvedAt    DateTime?         @map("approved_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [sellerId])

  @@map("wallet_transactions")
}

enum Role {
  SELLER
  CALL_CENTER
  ADMIN
}

enum OrderStatus {
  PENDING_BALANCE
  PENDING_CONFIRM
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  NO_ANSWER
}

enum TransactionType {
  DEPOSIT
  DEDUCTION
  PAYOUT
  REFUND
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}
